# Grafana Admin Credentials
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_in_production

# Alertmanager -> Slack
SLACK_WEBHOOK_DEPLOYS=https://hooks.slack.com/services/REPLACE/THIS/WEBHOOK

# Prometheus bearer token para scrape seguro em /api/metrics
# Copiar docker/monitoring/prometheus/secrets/prometheus_token.example para
# docker/monitoring/prometheus/secrets/prometheus_token
# com o mesmo token configurado no app em PROMETHEUS_TOKEN.
PROMETHEUS_TOKEN=REPLACE_WITH_PROMETHEUS_TOKEN

# Umami Analytics
UMAMI_DB_PASSWORD=YOUR_UMAMI_DB_PASSWORD_HERE
UMAMI_APP_SECRET=YOUR_UMAMI_APP_SECRET_HERE
