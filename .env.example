# Banco de Dados
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hallyuhub?schema=public"

# Kpopping Database (base separada com dados scrapeados do kpopping.com)
# Veja docs/KPOPPING_SETUP.md para instruções de criação do banco
KPOPPING_DATABASE_URL="postgresql://kpopping:your-kpopping-password@localhost:5432/kpopping_db"

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# NextAuth.js Authentication
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

NEXTAUTH_URL="http://localhost:3000"

# Google OAuth for NextAuth (sign-in with Google)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email Service — Resend (https://resend.com)
# Usado para: boas-vindas, reset de senha, notificações, digest
RESEND_API_KEY="re_YOUR_API_KEY_HERE"

# Email Service (Hostinger SMTP) — legado, substituído pelo Resend
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="no_reply@hallyuhub.com.br"
SMTP_PASSWORD="your-hostinger-email-password"
SMTP_FROM="no_reply@hallyuhub.com.br"
SMTP_FROM_NAME="HallyuHub"

# Filmography Sync Configuration
FILMOGRAPHY_SYNC_ENABLED=true
FILMOGRAPHY_SYNC_ON_CREATE=true
FILMOGRAPHY_SYNC_CONCURRENCY=3
FILMOGRAPHY_CACHE_TTL=86400

# TMDB API (OBRIGATÓRIO para artistas reais)
# Obtenha gratuitamente em: https://www.themoviedb.org/settings/api
# Permite 40 requisições a cada 10 segundos (gratuito)
TMDB_API_KEY="your-tmdb-api-key-here"

# Cron Job Security (OBRIGATÓRIO para produção)
# Generate with: openssl rand -hex 32
CRON_SECRET="your-secure-cron-token-here"

# AI Content Generation
# ESTRATÉGIA: TMDB (dados reais) + Ollama (bio gratuita) + Gemini Free Tier (fallback)

# Ollama (Recomendado - local, gratuito, usado para gerar bios em português)
OLLAMA_BASE_URL="http://localhost:11434"
# Otimização CPU: Limite threads para não travar o servidor (Recomendado: total_cpus / 2)
# OLLAMA_NUM_THREAD=2

# Dica de Performance: No Hostinger, use o script scripts/manage-staging.sh sleep
# para desligar homologação quando não estiver usando.

# Gemini Free Tier (Fallback - usado apenas se TMDB falhar)
GEMINI_API_KEY="your-gemini-api-key"

# OpenAI (Opcional - não recomendado por custo)
# OPENAI_API_KEY="your-openai-api-key"

# Anthropic Claude (Opcional - não recomendado por custo)
# ANTHROPIC_API_KEY="your-anthropic-api-key"

# Slack Notifications (opcional) — criar 3 Incoming Webhooks no Slack
# #hallyuhub-content: novos artistas, notícias, produções
SLACK_WEBHOOK_CONTENT="https://hooks.slack.com/services/YOUR/CONTENT/WEBHOOK"
# #hallyuhub-deploys: status de deploys e PRs
SLACK_WEBHOOK_DEPLOYS="https://hooks.slack.com/services/YOUR/DEPLOYS/WEBHOOK"
# #hallyuhub-alerts: health alerts, backups, erros críticos
SLACK_WEBHOOK_ALERTS="https://hooks.slack.com/services/YOUR/ALERTS/WEBHOOK"

# Google Analytics 4
# Obtenha em: https://analytics.google.com → Admin → Data Streams → Web → Measurement ID
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Google Search Console
# Obtenha em: https://search.google.com/search-console → Adicionar propriedade → Método "Tag HTML"
# Copie apenas o valor do atributo content da meta tag, ex: "abc123XYZ"
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="your-google-verification-code"

# Bing Webmaster Tools (opcional)
NEXT_PUBLIC_BING_SITE_VERIFICATION="your-bing-verification-code"

# Google AdSense
# Obtenha em: https://adsense.google.com → Anúncios → Por unidade de anúncio
NEXT_PUBLIC_ADSENSE_CLIENT="ca-pub-XXXXXXXXXXXXXXXX"
# 3 slots canônicos — criar cada um separadamente no AdSense
NEXT_PUBLIC_ADSENSE_SLOT_AUTO="XXXXXXXXXX"       # responsivo — usado na maioria das páginas
NEXT_PUBLIC_ADSENSE_SLOT_FLUID="XXXXXXXXXX"      # fluid in-article — dentro de artigos
NEXT_PUBLIC_ADSENSE_SLOT_MULTIPLEX="XXXXXXXXXX"  # autorelaxed — discovery no final de páginas

# GitHub Actions Secrets necessários
# SSH_PASSWORD=               — senha root do servidor (sync-staging.yml)
# COOLIFY_TOKEN=              — token da API do Coolify (deploy.yml + admin UI)
# COOLIFY_STAGING_UUID=       — UUID do app staging no Coolify (var)
# COOLIFY_PRODUCTION_UUID=    — UUID do app production no Coolify (var)

# Coolify API — admin/infrastructure UI
COOLIFY_TOKEN=your-coolify-api-token
COOLIFY_BASE_URL=http://YOUR_SERVER_IP:8000/api/v1
COOLIFY_PRODUCTION_UUID=your-production-app-uuid
COOLIFY_STAGING_UUID=your-staging-app-uuid

# Umami Self-hosted Analytics (server-side + client-side)
NEXT_PUBLIC_UMAMI_URL=http://YOUR_SERVER_IP:3003
NEXT_PUBLIC_UMAMI_WEBSITE_ID=YOUR_UMAMI_WEBSITE_ID_HERE
UMAMI_URL=http://YOUR_SERVER_IP:3003
UMAMI_WEBSITE_ID=YOUR_UMAMI_WEBSITE_ID_HERE
UMAMI_DB_PASSWORD=your-umami-db-password
UMAMI_APP_SECRET=your-umami-app-secret
